# ─────────────────────────────────────────────────────────────
# Auth Service — Variables de entorno
#
# USO:
#   cp .env.example .env
#   (edita .env con tus valores reales)
#   docker-compose up -d
#
# IMPORTANTE: nunca subas el archivo .env a Git.
#             .env.example sí se sube — es solo documentación.
# ─────────────────────────────────────────────────────────────

# ─── Base de datos ────────────────────────────────────────────
DB_USER=auth_user
DB_PASS=auth_pass
# En producción usa algo como: openssl rand -base64 32

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=
# En producción siempre pon contraseña a Redis

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_SERVERS=kafka:9092

# ─── JWT ──────────────────────────────────────────────────────
# Genera un secreto seguro con:
#   openssl rand -base64 64
JWT_SECRET=cambiar-este-secreto-en-produccion-minimo-256-bits

# ─── Spring ───────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
# Valores posibles: dev | staging | prod
